{
  "dxt_version": "0.2",
  "name": "firefly-mcp",
  "version": "0.1.0",
  "description": "The official MCP Server for the Firefly API",
  "author": {
    "name": "Firefly",
    "email": "james@firefly-iii.org"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/steel-gareth/firefly-typescript.git"
  },
  "homepage": "https://github.com/steel-gareth/firefly-typescript/tree/main/packages/mcp-server#readme",
  "documentation": "https://firefly-iii.org",
  "server": {
    "type": "node",
    "entry_point": "index.js",
    "mcp_config": {
      "command": "node",
      "args": [
        "${__dirname}/index.js"
      ],
      "env": {
        "FIREFLY_BEARER_TOKEN": "${user_config.FIREFLY_BEARER_TOKEN}"
      }
    }
  },
  "user_config": {
    "FIREFLY_BEARER_TOKEN": {
      "title": "bearer_token",
      "description": "Optional Bearer token flow",
      "required": false,
      "type": "string"
    }
  },
  "tools": [],
  "tools_generated": true,
  "compatibility": {
    "runtimes": {
      "node": ">=18.0.0"
    }
  },
  "keywords": [
    "api"
  ]
}
